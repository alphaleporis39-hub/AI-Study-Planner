{
  "version": 2,
  "routes": [
    {
      "src": "/(api/.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/blog",
      "dest": "backend/server.js"
    },
    {
      "src": "/blog/(.*)",
      "dest": "backend/server.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "backend/server.js"
    }
  ]
}